; EditorConfig — https://editorconfig.org
;
; Workspace-wide defaults for the x2p platform (Rust + TypeScript).

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 2

[*.rs]
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,toml,yml,yaml,html,css,scss}]
indent_size = 2

[*.md]
indent_size              = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
